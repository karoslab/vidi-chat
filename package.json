  "type": "module",
  "engines": {
    "node": ">=22.18"
  },
  "scripts": {
    "dev": "next dev -H 127.0.0.1 -p 4183",
    "build": "next build",
    "build:prod": "NEXT_DIST_DIR=.next-build next build",
